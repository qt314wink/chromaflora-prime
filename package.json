    "@react-three/drei": "^9.108.3",
    "@react-three/postprocessing": "^2.16.2",
    "@whatisjery/react-fluid-distortion": "^1.0.0",
    "three": "^0.168.0",
    "postprocessing": "^6.36.0",
    "tailwind-merge": "^2.4.0",
    "clsx": "^2.1.1",
    "zustand": "^4.5.4",
    "@tanstack/react-query": "^5.50.1",
    "lucide-react": "^0.408.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
