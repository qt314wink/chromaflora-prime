{
  "name": "chromaflora-prime",
  "version": "1.0.0",
  "description": "An immersive digital garden where code blooms into consciousness. Next.js 14 + WebGL + Framer Motion.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
